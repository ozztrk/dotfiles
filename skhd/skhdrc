# Reload yabai and skhd configuration
shift + cmd - r : yabai -m config layout bsp && skhd --reload

# Window focus within space
alt - j : yabai -m window --focus south
alt - k : yabai -m window --focus north
alt - h : yabai -m window --focus west
alt - l : yabai -m window --focus east

# Focus between external displays
alt - s : yabai -m display --focus north
alt - g : yabai -m display --focus south

# Move window
shift + alt - h : yabai -m window --warp west
shift + alt - j : yabai -m window --warp south
shift + alt - k : yabai -m window --warp north
shift + alt - l : yabai -m window --warp east

# Resize window (find better shortcuts)
ctrl + alt - right : yabai -m window --resize left:20:0  
ctrl + alt - down : yabai -m window --resize bottom:0:20 
ctrl + alt - up : yabai -m window --resize top:0:-20     
ctrl + alt - left : yabai -m window --resize right:-20:0 

# Modifying the Layout
shift + alt - r : yabai -m space --rotate 270
shift + alt - y : yabai -m space --mirror y-axis
shift + alt - x : yabai -m space --mirror x-axis
shift + alt - t : yabai -m window --toggle float --space 4:4:1:1:2:2

# Create new space/desktop
ctrl + alt - n : yabai -m space --create

# Move focused window to another space
shift + ctrl + alt - left : yabai -m window --space prev
shift + ctrl + alt - right : yabai -m window --space next


## Modifying Window Size
# maximize a window
shift + alt - m : yabai -m window --toggle zoom-fullscreen

# balance out tree of windows (resize to occupy same area)
shift + alt - e : yabai -m space --balance

